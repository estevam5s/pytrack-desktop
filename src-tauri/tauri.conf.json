{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PyTrack",
  "version": "1.0.1",
  "identifier": "com.pytrack.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PyTrack",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https:; font-src 'self' data: https://cdn.jsdelivr.net; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://cdn.jsdelivr.net https://api.stripe.com https://www.pytrack.com.br; worker-src 'self' blob:; child-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "\u00a9 2026 PyTrack",
    "category": "Education",
    "shortDescription": "Aprenda Python \u2014 do b\u00e1sico \u00e0 carreira",
    "longDescription": "App desktop oficial da PyTrack: trilhas, +5.000 exerc\u00edcios, IDE Python, comunidade e carreira.",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/estevam5s/pytrack-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDExRUQxOERDRkY0MDc0NTIKUldSU2RFRC8zQmp0RVpLY2ZRZ1BOQUdXamhlanpTaGNCWG55OW1NNUtHaGxoU1NYeHZWQUNmMkcK"
    }
  }
}